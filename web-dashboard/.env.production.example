# Production Environment Variables Example
# Copy this file to .env.production and replace with your actual values

# API Base URL - Your production backend URL
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1

# Mapbox Token for Maps
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Stripe Public Key (Production)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_your_production_stripe_public_key

# WebSocket URL (if different from API URL)
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
